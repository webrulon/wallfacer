# =============================================================================
# Claude Code sandbox (default)
# =============================================================================

# Authentication: set ONE of the two variables below.
CLAUDE_CODE_OAUTH_TOKEN=your-oauth-token-here
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: custom Anthropic-compatible API base URL.
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Optional: default model for Claude tasks.
# WALLFACER_DEFAULT_MODEL=

# Optional: model for auto-generating task titles (falls back to default model).
# WALLFACER_TITLE_MODEL=

# =============================================================================
# OpenAI Codex sandbox (use with wallfacer-codex image)
# =============================================================================

# Authentication: set your OpenAI API key.
# OPENAI_API_KEY=sk-...

# Optional: custom OpenAI-compatible API base URL.
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: default model for Codex tasks.
# CODEX_DEFAULT_MODEL=codex-mini-latest

# Optional: model for auto-generating task titles with Codex (falls back to CODEX_DEFAULT_MODEL).
# CODEX_TITLE_MODEL=codex-mini-latest
